{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // Must match the Workers project name in the Cloudflare dashboard.
  "name": "my-blog",
  "compatibility_date": "2026-07-12",
  // Static assets only — no Worker script, no server rendering.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
