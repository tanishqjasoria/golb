---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import Prompt from '@/components/Prompt.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  return courses.map((course) => ({ params: { course: course.id }, props: { course } }));
}

const { course } = Astro.props;
const { Content } = await render(course);

const lessons = (
  await getCollection('lessons', (lesson) => lesson.id.startsWith(`${course.id}/`))
).sort((a, b) => a.data.order - b.data.order);

const lessonSlug = (id: string) => id.split('/').at(-1) ?? id;
---
<Base
  title={`${course.data.title} — Tanishq Jasoria`}
  description={course.data.description}
  path={`tanishq@blog: ~/writing/courses/${course.id} — zsh`}
>
  <Prompt cmd="cat README.md" />
  <article class="prose">
    <header class="post-head">
      <h1>{course.data.title}</h1>
      <p class="meta">status: {course.data.status}</p>
    </header>
    <Content />
  </article>

  <div class="section">
    <Prompt cmd="ls ./lessons" />
    {lessons.length > 0 ? (
      <div class="listing">
        <div class="lhead"><span>LESSON</span><span>№</span></div>
        {lessons.map((lesson) => (
          <a class="entry" href={`/courses/${course.id}/${lessonSlug(lesson.id)}/`}>
            <span class="edate">{String(lesson.data.order).padStart(2, '0')}</span>
            <span class="ename">{lessonSlug(lesson.id)}.md</span>
            <span class="esize">{String(lesson.data.order).padStart(2, '0')}</span>
            <span class="edesc">{lesson.data.title} — {lesson.data.description}</span>
          </a>
        ))}
      </div>
    ) : (
      <p class="comment">lessons land here as they are written.</p>
    )}
  </div>

  <footer class="site">
    <div class="links">
      <a href="/">cd ~ ↩</a>
    </div>
  </footer>
</Base>
